server {
	listen 80 default_server;
	listen [::]:80 default_server;
	root /var/www/html;
	index index.html index.htm index.nginx-debian.html;
	server_name _;
	location / {
		try_files $uri $uri/ =404;
	}
	location ~ \.pl$ {
		# Prevent downloading of perl scripts
		return 404;
	}
	location = /acs {
		# Set lots of fcgi ENV variables; see /etc/nginx/fastcgi_params
		include fastcgi_params;

		# Use the right socket for talking to fcgiwrap
		# see /usr/lib/systemd/system/fcgiwrap.socket
		fastcgi_pass  unix:/run/fcgiwrap.socket;

		# Tell fcgiwrap which script file to use
		fastcgi_param SCRIPT_FILENAME $document_root/acs.pl;
	}
}
